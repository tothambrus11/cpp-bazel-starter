# =============================================================================
# Multi-compiler configuration.
#
# Pick a compiler by exporting CC/CXX (e.g. CC=gcc-14, CXX=g++-14) and passing
# one of:
#     --config=gcc     GCC
#     --config=clang   Clang
#     --config=msvc    MSVC (Windows)
# =============================================================================

build --cxxopt=-std=c++23 --host_cxxopt=-std=c++23

# Pick up CC/CXX changes without requiring a clean.
build --repo_env=CC --repo_env=CXX

# -----------------------------------------------------------------------------
# Strict warnings are scoped to first-party sources (under main/) via
# --per_file_copt so external deps (e.g. catch2) are unaffected. Bazel uses
# RE2 here, which has no lookahead -- so we use a positive match rather than
# excluding external/. Extend the regex if you add new top-level source dirs.
# -----------------------------------------------------------------------------

# Warnings understood by both GCC and Clang.
build:_warn_gnu --per_file_copt=^main/.*@-Wall,-Wextra,-Wpedantic,-Wshadow,-Wconversion,-Wsign-conversion,-Wcast-align,-Wdouble-promotion,-Wformat=2,-Wimplicit-fallthrough,-Wunused,-Wnon-virtual-dtor,-Wold-style-cast,-Woverloaded-virtual,-Werror

build:gcc --config=_warn_gnu
build:gcc --per_file_copt=^main/.*@-Wduplicated-cond,-Wduplicated-branches,-Wlogical-op,-Wnull-dereference,-Wuseless-cast

build:clang --config=_warn_gnu
build:clang --per_file_copt=^main/.*@-Wthread-safety,-Wshadow-all

build:msvc --cxxopt=/std:c++latest --host_cxxopt=/std:c++latest
build:msvc --per_file_copt=^main/.*@/W4,/permissive-,/WX,/w14242,/w14254,/w14263,/w14265,/w14287,/w14296,/w14311,/w14545,/w14546,/w14547,/w14549,/w14555,/w14619,/w14640,/w14826,/w14905,/w14906,/w14928

# -----------------------------------------------------------------------------
# CI convenience.
# -----------------------------------------------------------------------------
build:ci --color=yes
test:ci --test_output=errors --test_summary=terse
